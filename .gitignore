/hazelcast/

# Rust build output
target/
**/target/

# Python venv
.venv/
conformance-python/.venv/

# Java build
conformance-java/target/

__pycache__/
*.pyc

# Local JDK/Maven (downloaded, not committed)
/.tools/
.gstack/

# Go loadgen build artifact (bench/run-all.sh builds it in a container)
bench/loadgen/loadgen

# Generated Bencher Metric Format (bench/track.sh regenerates from combined.json)
bench/loadgen/bmf.json

# memtier intermediate artifacts (regenerated by run-memtier.sh)
bench/loadgen/memtier/
bench/loadgen/memtier-bmf.json

# open-loop per-backend intermediates (openloop-combined.json is the committed merge)
bench/loadgen/results-open-*.json

# go-ycsb binary (95MB; rebuilt by run-ycsb.sh) + per-workload intermediates
bench/ycsb/go-ycsb
bench/loadgen/ycsb/

# Secrets & key material — never commit (CI also enforces this via gitleaks).
# Test certs are generated at runtime (rcgen), never checked in; use `git add -f`
# only for a deliberate, reviewed test fixture.
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.truststore
.env
.env.*
*.env
.netrc
.pgpass
id_rsa
id_ed25519
*.pkcs12
# gitleaks scratch report (never commit)
.gitleaks-report.json
